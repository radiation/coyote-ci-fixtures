COYOTE_BASE_URL=http://localhost:8080
COYOTE_PROJECT_SLUG=fixtures
COYOTE_PROJECT_NAME=Coyote Fixtures
COYOTE_FIXTURES_REPO_URL=https://github.com/radiation/coyote-ci-fixtures.git
COYOTE_FIXTURES_REF=main
# Optional. JSON array of users to create before job sync. Elements can be
# either email strings or objects with email, display_name, and global_role.
COYOTE_BOOTSTRAP_USERS=[{"email":"fixture-admin@example.com","display_name":"Fixture Admin","global_role":"admin"},{"email":"fixture-user@example.com","display_name":"Fixture User","global_role":"user"}]
# Optional. If set, the script sends Authorization: Bearer <token>.
# Create one after logging in to Coyote with POST /api/me/tokens.
# Raw API tokens are shown only once when created in Coyote.
COYOTE_API_TOKEN=

AUTH_MODE=oidc
OIDC_ISSUER_URL=https://accounts.google.com
OIDC_CLIENT_ID=your-google-client-id
OIDC_CLIENT_SECRET=your-google-client-secret
OIDC_REDIRECT_URL=http://localhost:8080/auth/callback
OIDC_SCOPES=openid email profile
SESSION_SECRET=replace-with-a-long-random-secret
SESSION_COOKIE_SECURE=false
BOOTSTRAP_ADMIN_EMAILS=your-email@gmail.com
